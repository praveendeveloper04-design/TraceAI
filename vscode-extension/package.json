{
    "name": "traceai",
    "displayName": "TraceAI",
    "description": "AI-powered developer investigation platform — investigate bugs, incidents, and user stories with Claude",
    "version": "1.0.0",
    "publisher": "traceai",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other",
        "Machine Learning"
    ],
    "keywords": [
        "ai",
        "investigation",
        "bugs",
        "claude",
        "langchain",
        "developer-tools",
        "traceai"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            { "command": "traceai.setup", "title": "TraceAI: Run Setup Wizard", "icon": "$(gear)" },
            { "command": "traceai.refresh", "title": "TraceAI: Refresh Tasks", "icon": "$(refresh)" },
            { "command": "traceai.refreshTasks", "title": "TraceAI: Refresh Tasks", "icon": "$(refresh)" },
            { "command": "traceai.investigate", "title": "TraceAI: Investigate Task", "icon": "$(search)" },
            { "command": "traceai.viewReport", "title": "TraceAI: View Investigation Report", "icon": "$(file-text)" },
            { "command": "traceai.showStatus", "title": "TraceAI: Show Status", "icon": "$(info)" },
            { "command": "traceai.status", "title": "TraceAI: Show Status", "icon": "$(info)" },
            { "command": "traceai.history", "title": "TraceAI: Refresh History", "icon": "$(history)" },
            { "command": "traceai.deleteInvestigation", "title": "Delete Investigation", "icon": "$(trash)" },
            { "command": "traceai.deleteInvestigationHistory", "title": "TraceAI: Delete All History", "icon": "$(clear-all)" },
            { "command": "traceai.rerunInvestigation", "title": "Re-run Investigation", "icon": "$(debug-restart)" },
            { "command": "traceai.cancelInvestigation", "title": "Cancel Investigation", "icon": "$(debug-stop)" }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "traceai",
                    "title": "TraceAI",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "traceai": [
                {
                    "id": "traceai.tasks",
                    "name": "My Tasks",
                    "type": "tree"
                },
                {
                    "id": "traceai.investigations",
                    "name": "Investigations",
                    "type": "tree"
                }
            ]
        },
        "menus": {
            "view/title": [
                { "command": "traceai.refresh", "when": "view == traceai.tasks", "group": "navigation" },
                { "command": "traceai.setup", "when": "view == traceai.tasks", "group": "navigation" },
                { "command": "traceai.history", "when": "view == traceai.investigations", "group": "navigation" },
                { "command": "traceai.deleteInvestigationHistory", "when": "view == traceai.investigations", "group": "navigation" }
            ],
            "view/item/context": [
                { "command": "traceai.investigate", "when": "viewItem == task", "group": "inline" },
                { "command": "traceai.deleteInvestigation", "when": "viewItem == investigation", "group": "1_actions" },
                { "command": "traceai.rerunInvestigation", "when": "viewItem == investigation", "group": "1_actions" },
                { "command": "traceai.cancelInvestigation", "when": "viewItem == investigation", "group": "1_actions" }
            ]
        },
        "configuration": {
            "title": "TraceAI",
            "properties": {
                "traceai.serverPort": {
                    "type": "number",
                    "default": 7420,
                    "description": "Port for the TraceAI API server"
                },
                "traceai.autoStartServer": {
                    "type": "boolean",
                    "default": true,
                    "description": "Automatically start the API server when VS Code opens"
                },
                "traceai.defaultAssignee": {
                    "type": "string",
                    "default": "",
                    "description": "Default assignee filter for task fetching"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts",
        "bundle-backend": "node scripts/bundle-backend.js",
        "prepackage": "npm run bundle-backend && npm run compile",
        "package": "npm run prepackage && vsce package",
        "publish": "vsce publish"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "@vscode/vsce": "^2.15.0",
        "eslint": "^8.56.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "axios": "^1.13.6"
    }
}
